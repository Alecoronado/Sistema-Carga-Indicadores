# Ejemplo de archivo .env para desarrollo local
# NO subir este archivo a GitHub (ya está en .gitignore)

# Para desarrollo local con PostgreSQL (opcional)
# Descomenta y configura si quieres usar PostgreSQL localmente
# DATABASE_URL=postgresql://usuario:password@localhost:5432/indicadores

# Railway configurará DATABASE_URL automáticamente en producción

# URL de la API (Backend)
# Local: http://localhost:8000
# Producción: https://tu-api-en-railway.app
API_URL=http://localhost:8000
